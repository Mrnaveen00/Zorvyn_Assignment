              "raw": "{\n  \"name\": \"Operations User\",\n  \"email\": \"ops.user@companyx.com\",\n  \"password\": \"OpsUser@123\",\n  \"role\": \"VIEWER\",\n  \"status\": \"ACTIVE\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/users",
              "host": ["{{baseUrl}}"],
              "path": ["users"]
